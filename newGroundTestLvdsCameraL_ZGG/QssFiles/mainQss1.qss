QMainWindow {
    background-color: qlineargradient(
        spread: pad,
        x1: 0, y1: 0,
        x2: 1, y2: 1,
		stop: 0 #90CEF5,
		stop: 1 #FCEAFF	
    ); /*注意：使用这种方式修饰背景时，四个边角是无法修剪的，一直是直角*/
	border-radius:4px; /*给ui界面的四个边角添加一个弧度，更圆润*/
    border: 1px solid transparent;
}

/* 设置标签区域（QTabBar）的背景 */
QTabBar {
    background-color: transparent;  /* 使 TabBar 背景透明 */
    border: none;  /* 移除边框 */
}

QTabWidget::pane {
    /* background-color: transparent; */
    background-color: rgba(255,255,255,150);
    /* border: 1px solid gray; */
    border: none;
}


QListWidget {
    background-color: rgba(195,222,251,0); /* 标签栏背景色（浅灰，柔和）*/
    /* border-right: 1px solid #ddd; 右侧分隔线（区分标签栏与页面） */
    outline: none; /* 去掉选中时的虚线框*/
    padding: 0px 0; /* 上下内边距（10px，让Item与标签栏顶部/底部有间隔）*/
}

QListWidget::item:hover {
    background-color: qlineargradient(
        spread: pad,
        x1: 0, y1: 0,
        x3: 0, y2: 1,
		stop: 0 #90CEF5,
		stop: 1 #FCEAFF	
    );
    border-left: 3px solid rgb(21,106,183);
}

QListWidget::item:checked {
    background-color: qlineargradient(
        spread: pad,
        x1: 0, y1: 0, 
        x2: 0, y2: 1,
		stop: 0 #90CEF5,
		stop: 1 #FCEAFF	
    );
    border-left: 3px solid rgb(21,106,183);
}

QListWidget::item:selected {
    background-color: qlineargradient(
        spread: pad,
        x1: 0, y1: 0, 
        x2: 0, y2: 1,
		stop: 0 #90CEF5,
		stop: 1 #FCEAFF	
    );
    border-left: 3px solid rgb(21,106,183);
}


