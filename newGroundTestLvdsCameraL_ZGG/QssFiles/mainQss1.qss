/* 设置 QTabWidget 的内容区域背景透明 */
QTabWidget{
    background-color: rgba(255,255,255,0);   /*有效*/
    /* background: transparent; 设置内容区域的背景为透明 */
}

QTabWidget QWidget {
    background-color: rgba(255,255,255,0);
}


/*表格切换目录样式 */

QTabBar::tab
{ 
	/* background:blue; */
	background-color: rgba(255,255,255,40); /*设置每个标签页的背景为透明*/ /*有效*/
	border-bottom: 0px solid rgba(255, 242, 251,100);
	font-family:"微软雅黑";
	font-size:14px;
	padding-left:5px;
	padding-right:5px;
	min-width: 111px;
	min-height:40px;		
}

