QPlainTextEdit{
    background-color: rgba(255,255,255,150);
}

QLineEdit{
    background-color: rgba(255,255,255,150);
}

QLabel {
    font-size: 12px;
    font-family: "SimSun";
    /* color: darkgray; */
}

QGroupBox{
    /* background: pink; */
    background-color: rgba(255,255,255,0);
}

/*设置groupbox的标题颜色*/
QGroupBox::title {
    font-size: 16px;
    font-family: "SimSun";
    color: rgb(5,127,238);
}


QTabWidget QPlainTextEdit {
    background-color: rgba(255, 255, 255, 40);  /* 按钮的背景色 */
}

/* 不直接使用QPushButton，需要加上其所属的容器才行 */
QTabWidget QPushButton {
    background-color: rgba(195,222,251,100);  /* 按钮的背景色 */
}

/*按钮样式*，注意，这个样式只能针对独立的按钮生效，比如位于QWidget中的按钮就会继承QWidget的样式而不使用该样式*/
QPushButton{
    font-family: "SimSun";
    font-size: 13px;
    color:#333333;
    border: 1px solid #8c8c8c;
    /* border: none;  */
    border-radius: 3px;        /* 圆角（可选） */
    padding: 5px;              /* 按钮内边距 */
    /* background-color: #b2d4f5, */
    background: none;  /* 先清除继承的背景 */
    background-color: rgba(195,222,251,100); /* Corrected alpha value */
}

QPushButton:hover,:checked{
    font-family: "SimSun";
    font-size: 13px;
    color:#333333;
    border: 1px solid #8c8c8c; /* 按钮边框颜色 */
    border-radius: 3px;        /* 圆角（可选） */
    padding: 5px;              /* 按钮内边距 */
    background-color: qlineargradient(
        spread: pad,
        x1: 0, y1: 0, x2: 0, y2: 1,
		stop: 0 #b2d4f5,
		/* stop: 0.5 #bbd4f3,  */
		stop: 1 #d7e0fd
    );
}

QTabWidget QLineEdit {
    /* background-color: rgb(171, 210, 235);  下拉框的背景色 */
    font-family: "Times New Roman","SimSun";
    background-color: rgba(195,222,251,100);
    font-size: 14px
}

QTabWidget QComboBox {
    font-family: "Times New Roman";
    /* background-color: rgb(171, 210, 235);  下拉框的背景色 */
    background-color: rgb(195,222,251);
    font-size: 12px
}

QComboBox{
    background-color: rgb(195,222,251);
}

QComboBox QAbstractItemView {
    background-color: rgba(195,222,251,100);
    border: 1px solid #cccccc;  /* 下拉框边框颜色 */
    border-radius: 3px;  
    font-size: 12px;  /* 设置字体大小 */
}

QComboBox::item:selected {
    background-color: rgb(171, 210, 235); /* 默认选择项的背景色 */
    color: white; /* 默认选择项的字体颜色 */
}

QMenu {
    background-color: white;  /* 设置菜单背景颜色 */
    color: white;  /* 设置菜单文本颜色 */
}

QMenu::item {
    background-color: rgb(195,222,251);  /* 设置选项的背景颜色 */
    color: #333333;
}

QMenu::item:selected {
    background-color: rgb(171, 210, 235);  /* 设置选中项的背景颜色 */
    color: white;
}


