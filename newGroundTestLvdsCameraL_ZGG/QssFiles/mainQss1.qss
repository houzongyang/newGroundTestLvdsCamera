/*表格切换目录样式*/
QTabBar::tab:selected
{
    background-color: rgba(255,255,255,40);/*有效*/
	/* border-bottom: 3px solid rgb(236,65,65); */
    border-bottom: 3px solid rgb(21,106,183);
	color: rgb(55,55,55);
	font-size:18px;
	font-weight: bold;
}

